    "collapsible_tabs_PmJJ83": {
      "type": "collapsible-tabs",
      "blocks": {
        "collapsible_item_z3WjLd": {
          "type": "collapsible_item",
          "settings": {
            "icon": "none",
            "heading": "Standard 6-Month Warranty(Automatically Applies to All Purchases)",
            "content": "",
            "custom_liquid": "<ul>\n    <li class=\"dc_content-text \">\n      <span class=\"dc_content-bullet \">Coverage Duration:</span>\n      <ul class = \"dc_hide-bullets dc_margin-top\">\n        <li class=\"dc_content-text \">6 months from the date of purchase.</li>\n      </ul>\n    </li>\n\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet\">What's Covered:</span>\n      <ul class = \"dc_hide-bullets dc_margin-top\">\n        <li class=\"dc_content-text \">Manufacturing defects in materials and\n          workmanship, including the sprayer unit, pump, battery, electronic components, and seals.</li>\n      </ul>\n    </li>\n\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet\">Resolution:</span>\n      <ul class = \"dc_hide-bullets dc_margin-top\">\n        <li class=\"dc_content-text\">We will provide replacement parts or a full\n          unit replacement as necessary.</li>\n      </ul>\n    </li>\n\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet\">Shipping Costs:</span>\n      <ul class = \"dc_hide-bullets dc_margin-top\">\n        <li class=\"dc_content-text \">We will cover all shipping costs for approved\n          warranty claims.</li>\n      </ul>\n    </li>\n\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet\">What's Not Covered:</span>\n      <ul class = \"dc_hide-bullets dc_margin-top\">\n        <li class=\"dc_content-text \"><span class=\"dc_bullet-icon\">◦</span>Labor costs.</li>\n        <li class=\"dc_content-text\"><span class=\"dc_bullet-icon\">◦</span>Misuse, abuse, neglect, improper storage, or\n          failure to follow operating instructions.</li>\n        <li class=\"dc_content-text\"><span class=\"dc_bullet-icon\">◦</span>Unauthorized repairs or modifications.</li>\n        <li class=\"dc_content-text\"><span class=\"dc_bullet-icon\">◦</span>Damage caused by chemicals or solutions not\n          approved for use with the sprayer.</li>\n      </ul>\n    </li>\n  </ul>",
            "page": "",
            "open": false,
            "use_subtext_color": false
          }
        },
        "collapsible_item_Qrrhfn": {
          "type": "collapsible_item",
          "settings": {
            "icon": "none",
            "heading": "Free Extended 1-Year Warranty(Opt-In Registration Required)",
            "content": "",
            "custom_liquid": "<ul>\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet dc_margin-top \">Coverage Duration:</span>\n      <ul class = \"dc_hide-bullets dc_margin-top\">\n        <li>\n          Extends coverage to <span class =\"dc_content-bold-text\">1 year from the date of purchase</span> when the product is registered within <span class =\"dc_content-bold-text\">30 days of purchase</span>.</span>\n        </li>\n      </ul>\n    </li>\n\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet\">What's Covered:</span>\n      <ul class = \"dc_hide-bullets dc_margin-top\">\n        <li class=\"dc_content-text\"><span class=\"dc_bullet-icon\">◦</span>Manufacturing defects in the sprayer unit, pump, battery, electronic components, and\n          other functional components.</li>\n        <li class=\"dc_content-text\"><span class=\"dc_bullet-icon\">◦</span>We will provide replacement parts or <span class=\"dc_content-bold-text\">Up to one full unit replacement</span> within the 1\n          year based on our determination.</li>\n      </ul>\n    </li>\n\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet\">Shipping Costs:</span>\n      <ul class = \"dc_hide-bullets dc_margin-top\">\n        <li class=\"dc_content-text\">We will cover all shipping costs for approved warranty claims.</li>\n      </ul>\n    </li>\n\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet\">What's Not Covered:</span>\n      <ul class = \"dc_hide-bullets dc_margin-top\">\n        <li class=\"dc_content-text\"><span class=\"dc_bullet-icon\">◦</span>Misuse, abuse, neglect, improper storage, or failure to follow operating\n          instructions.</li>\n        <li class=\"dc_content-text\"><span class=\"dc_bullet-icon\">◦</span>Unauthorized repairs or modifications.</li>\n        <li class=\"dc_content-text\"><span class=\"dc_bullet-icon\">◦</span>Damage caused by chemicals or solutions not approved for use with the sprayer.</li>\n      </ul>\n    </li>\n  </ul>",
            "page": "",
            "open": false,
            "use_subtext_color": false
          }
        },
        "collapsible_item_fnMQgk": {
          "type": "collapsible_item",
          "settings": {
            "icon": "none",
            "heading": "How to Register for the Extended Warranty",
            "content": "",
            "custom_liquid": "<span class=\"dc_content-text\">\n    To activate the <span class=\"dc_content-bold-text\">free extended 1-year warranty</span>, register your product\n    within <span class=\"dc_content-bold-text\">30 days of purchase.</span> at: www.petratools.com/warranty\n  </span>",
            "page": "",
            "open": false,
            "use_subtext_color": false
          }
        },
        "collapsible_item_dwRtxR": {
          "type": "collapsible_item",
          "settings": {
            "icon": "none",
            "heading": "Warranty Claim Process",
            "content": "",
            "custom_liquid": "<ul>\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet\">Contact Us:</span>\n      <ul class = \"dc_margin-top dc_hide-bullets\">\n        <li class=\"dc_content-text\">Reach out to our support team at support@petratools.com for assistance.</li>\n      </ul>\n    </li>\n\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet\">Provide Proof of Purchase & Details:</span>\n      <ul class = \"dc_margin-top dc_hide-bullets\">\n        <li class=\"dc_content-text\">Proof of purchase is required for all claims.</li>\n      </ul>\n    </li>\n\n    <li class=\"dc_content-text\">\n      <span class=\"dc_content-bullet\">Shipping & Replacement:</span>\n      <ul class = \"dc_margin-top dc_hide-bullets\">\n        <li class=\"dc_content-text\">Once approved, we will provide replacement parts or a full unit replacement at no\n          cost, including shipping.</li>\n      </ul>\n    </li>\n  </ul>",
            "page": "",
            "open": false,
            "use_subtext_color": false
          }
        },
        "collapsible_item_yymbaT": {
          "type": "collapsible_item",
          "settings": {
            "icon": "none",
            "heading": "Important Notes",
            "content": "",
            "custom_liquid": "<ul>\n    <li class=\"dc_content-text dc_margin-top \">\n      This warranty is <span class=\"dc_content-bold-text\">non-transferable</span>and applies only to the<span class=\"dc_content-bold-text\">original purchaser.</span>\n    </li>\n    <li class=\"dc_content-text dc_margin-top \">\n      The warranty does <span class=\"dc_content-bold-text\">not cover labor costs</span> associated with installation or\n      repairs.\n    </li>\n    <li class=\"dc_content-text dc_margin-top \">\n      Damage caused by <span class=\"dc_content-bold-text\">misuse, abuse, alterations, or unapproved chemicals</span> will\n      void the warranty.\n    </li>\n  </ul>",
            "page": "",
            "open": false,
            "use_subtext_color": false
          }
        }
      },

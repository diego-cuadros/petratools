{%- doc -%}
  Renders a list of product's price (regular, sale)

  @param {object} [product] - Product Liquid object
  @param {boolean} [use_variant] - Renders selected or first variant price instead of overall product pricing
  @param {boolean} [use_price_at_quantity_break_min] - Show variant price instead of quantity break price
  @param {boolean} [available_min_price_only] - Uses the cheapest available variant for visible non-season pricing
  @param {string} [price_class] - CSS class added to the price element
  @param {string} [price_regular_class] - CSS class added to the price regular element
  @param {string} [price_sale_class] - CSS class added to the price sale element
  @param {string} [alignment] - Alignment content for price element

  @example
  {% render 'price', product: product %}
{%- enddoc -%}
{%- liquid
  assign selected_variant = product.selected_or_first_available_variant
  if use_variant
    assign target = selected_variant
  else
    assign target = product
  endif

  assign compare_at_price = target.compare_at_price
  assign price = target.price | default: 1999
  assign price_min = product.price_min
  assign price_max = product.price_max

  if product.quantity_price_breaks_configured? and use_variant and selected_variant.quantity_price_breaks.size > 0
    assign price_min = selected_variant.price
    assign price_max = selected_variant.price

    unless use_price_at_quantity_break_min
      for price_break in selected_variant.quantity_price_breaks
        assign price_min = price_min | at_most: price_break.price
      endfor
    endunless
  endif

  assign display_compare_at_price = compare_at_price
  assign display_price = price
  assign display_price_min = price_min
  assign display_price_max = price_max

  if available_min_price_only and use_variant != true and product.available
    assign lowest_available_variant = blank
    for variant in product.variants
      if variant.available
        if lowest_available_variant == blank or variant.price < lowest_available_variant.price
          assign lowest_available_variant = variant
        endif
      endif
    endfor

    if lowest_available_variant != blank
      assign display_compare_at_price = lowest_available_variant.compare_at_price
      assign display_price = lowest_available_variant.price | default: 1999
      assign display_price_min = lowest_available_variant.price
      assign display_price_max = lowest_available_variant.price
    endif
  endif

  assign available = target.available | default: false
  assign money_price = display_price | money
  assign money_price_min = display_price_min | money
  assign money_price_max = display_price_max | money
  if settings.currency_code_enabled
    assign money_price = display_price | money_with_currency
    assign money_price_min = display_price_min | money_with_currency
    assign money_price_max = display_price_max | money_with_currency
  endif

  if target == product and product.price_varies and available_min_price_only != true
    assign money_price = money_price_min
  endif
-%}

{%- liquid
  assign price_font = block.settings.price_font_family
-%}

{%- style -%}
  {{ price_font | font_face: font_display: 'swap' }}
{%- endstyle -%}

{%- liquid
  assign use_season_price_from_variants = product.metafields.custom.season_price_use_from_variants.value | default: product.metafields.custom.season_price_use_from_variant.value
  assign selected_variant_price = selected_variant.price
  assign selected_variant_compare_at_price = selected_variant.compare_at_price

  assign season_price_from_variant = blank
  if selected_variant.metafields.custom.season_price_variant.value != blank
    assign season_price_from_variant = selected_variant.metafields.custom.season_price_variant.value | times: 100
  endif

  assign season_discount_percentage = 0
  if product.metafields.custom.season_price_discount_percentage.value != blank
    assign season_discount_percentage = product.metafields.custom.season_price_discount_percentage.value | plus: 0
  else
    assign season_discount_percentage = block.settings.season_discount_percentage | plus: 0
  endif
  assign season_discount_decimal = season_discount_percentage | divided_by: 100.0
  assign season_multiplier = 1 | minus: season_discount_decimal
  assign final_season_price = display_price | times: season_multiplier

  assign use_season_price_for_discount = false
  if block.settings.show_season_price or product.metafields.custom.use_season_price.value
    assign use_season_price_for_discount = true
  endif

  assign strike_sale_price_for_collection_season = false
  if template.name != 'product' and use_season_price_for_discount
    assign strike_sale_price_for_collection_season = true
  endif

  assign hide_from_price = false
  if use_season_price_for_discount and target == product and product.price_varies
    assign hide_from_price = true
  endif

  assign discount_price_source = display_price
  if use_season_price_for_discount
    assign discount_price_source = final_season_price
  endif

  assign discount_percentage = 0
  assign show_percentage_discount_tag = false
  assign has_compare_at_price = false
  if display_compare_at_price != blank and display_compare_at_price > 0
    assign has_compare_at_price = true
  endif

  if use_season_price_from_variants and season_price_from_variant
    if selected_variant_compare_at_price != blank and selected_variant_compare_at_price > season_price_from_variant
      assign difference = selected_variant_compare_at_price | minus: season_price_from_variant
      assign discount_percentage = difference | times: 100 | divided_by: selected_variant_compare_at_price
      assign show_percentage_discount_tag = true
    elsif selected_variant_price > season_price_from_variant and season_price_from_variant > 0
      assign difference = selected_variant_price | minus: season_price_from_variant
      assign discount_percentage = difference | times: 100 | divided_by: selected_variant_price
      assign show_percentage_discount_tag = true
    endif
  elsif has_compare_at_price
    if display_compare_at_price > discount_price_source
      assign difference = display_compare_at_price | minus: discount_price_source
      assign discount_percentage = difference | times: 100 | divided_by: display_compare_at_price
      assign show_percentage_discount_tag = true
    endif
  elsif use_season_price_for_discount
    if display_price > final_season_price and display_price > 0
      assign difference = display_price | minus: final_season_price
      assign discount_percentage = difference | times: 100 | divided_by: display_price
      assign show_percentage_discount_tag = true
    endif
  endif
-%}
{% if template.name != 'product' %}
  <style>
    @media only screen and (max-width: 749px) {
      .f-price__sale,
      .f-price-item,
      .f-price-item--regular {
        font-size: 14px !important;
      }
    }
  </style>
{% endif %}

<div
  class="
    f-price
    {%- if alignment %} f-price--{{ alignment }}{% endif -%}
    {%- if price_class %} {{ price_class }}{% endif -%}
    {%- if available == false %} f-price--sold-out {% endif -%}
    {%- if display_compare_at_price > display_price %} f-price--on-sale {% endif -%}
    {%- if target.price_varies == false and target.compare_at_price_varies %} f-price--no-compare{% endif -%}
  "
>
  {% if template.name == 'product' %}
    <div class="dc_season-row">
      {% unless use_season_price_from_variants %}
        {% if block.settings.show_season_price or product.metafields.custom.use_season_price.value %}
          <div class="dc_season-price-box" style="background-color: {{ block.settings.season_price_background }};">
            <span style="color: {{ block.settings.season_price_color }};">{{ final_season_price | money }}</span>
          </div>
        {% endif %}
      {% else %}
        {% if season_price_from_variant %}
          <div class="dc_season-price-box" style="background-color: {{ block.settings.season_price_background }};">
            <span style="color: {{ block.settings.season_price_color }};">
              {{- season_price_from_variant | money -}}
            </span>
          </div>
        {% endif %}
      {% endunless %}
    </div>
  {% endif %}

  {%- comment -%}
    Explanation of description list:
      - div.price__regular: Displayed when there are no variants on sale
      - div.price__sale: Displayed when a variant is a sale
  {%- endcomment -%}
  {%- unless hide_from_price -%}
    <div class="f-price__regular{% if price_regular_class %} {{ price_regular_class }}{% endif %}">
      {%- if product.quantity_price_breaks_configured? and price_min != price_max -%}
        <span class="visually-hidden visually-hidden--inline">{{ 'products.product.price.regular_price' | t }}</span>
        <span class="f-price-item f-price-item--regular">
          {{- 'products.product.volume_pricing.price_range' | t: minimum: money_price_min, maximum: money_price_max -}}
        </span>
      {%- else -%}
        <span class="visually-hidden visually-hidden--inline">{{ 'products.product.price.regular_price' | t }}</span>
        <span
          class="f-price-item f-price-item--regular"
          style="color: {{ block.settings.price_color }}; font-size: {{ block.settings.price_font_size }}px;"
        >
          {{ money_price }}
        </span>
      {%- endif -%}
    </div>
  {%- endunless -%}

  {%- unless hide_from_price -%}
    <div class="f-price__sale{% if price_sale_class %} {{ price_sale_class }}{% endif %}">
      {%- capture regular_price_markup -%}
      <span class="visually-hidden visually-hidden--inline">{{ 'products.product.price.sale_price' | t }}</span>
      <span
        class="f-price-item f-price-item--sale"
        style="
          {% if strike_sale_price_for_collection_season %}color:#858484; {% else %} color: {{ block.settings.price_color }};{% endif %} font-size: {{ block.settings.price_font_size }}px; font-family: {{ price_font.family }}, {{ price_font.fallback_families }};
          font-weight: {{ price_font.weight }};
          {% if strike_sale_price_for_collection_season %}text-decoration: line-through;{% endif %}
        "

      >
        {{ money_price }}
      </span>
    {%- endcapture -%}
      {%- capture compare_at_markup -%}
      {%- unless target.price_varies == false and target.compare_at_price_varies %}
        <span class="visually-hidden visually-hidden--inline">{{ 'products.product.price.regular_price' | t }}</span>
        <span class="f-price-item f-price-item--regular">
          <s
            style="
                 color: {{ block.settings.strike_through_price_color }}; {% if block.settings.use_same_size_for_compare_at_price %}
                   font-size: {{ block.settings.price_font_size }}px;
                 {% endif %}
                  font-family: {{ price_font.family }}, {{ price_font.fallback_families }};
              font-weight: {{ price_font.weight }};;
            "
          >
            {% if settings.currency_code_enabled %}
              {{ display_compare_at_price | money_with_currency }}
            {% else %}
              {{ display_compare_at_price | money }}
            {% endif %}
          </s>
        </span>
      {%- endunless -%}
    {%- endcapture -%}

      {%- assign regular_price_first = block.settings.regular_price_first -%}
      {%- if has_compare_at_price -%}
        {%- assign regular_price_first = true -%}
      {%- endif -%}

      {%- if regular_price_first -%}
        {{ regular_price_markup }}
        {{ compare_at_markup }}
      {%- else -%}
        {{ compare_at_markup }}
        {{ regular_price_markup }}
      {%- endif -%}
    </div>
  {%- endunless -%}

  {%- if hide_from_price and has_compare_at_price -%}
    <div class="f-price__sale{{ price_sale_class | prepend: ' ' }}">
      <span class="visually-hidden visually-hidden--inline">{{ 'products.product.price.regular_price' | t }}</span>
      <span class="f-price-item f-price-item--regular">
        <s
          style="
            color: {{ block.settings.strike_through_price_color }};
            {% if block.settings.use_same_size_for_compare_at_price %}font-size: {{ block.settings.price_font_size }}px;{% endif %}
            font-family: {{ price_font.family }}, {{ price_font.fallback_families }};
            font-weight: {{ price_font.weight }};
          "
        >
          {%- if settings.currency_code_enabled -%}
            {{ display_compare_at_price | money_with_currency }}
          {%- else -%}
            {{ display_compare_at_price | money }}
          {%- endif -%}
        </s>
      </span>
    </div>
  {%- endif -%}

  {% if block.settings.use_percentage_discount_tag %}
    {%- if show_percentage_discount_tag -%}
      <div
        class="dc_discount_tag"
        style="background-color: {{ block.settings.tag_color }};color: {{ block.settings.tag_text_color }};"
      >
        {{ discount_percentage | round }}% OFF
      </div>
    {% endif %}
  {%- endif -%}

  <style>
    .dc_season-row {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    @media screen and (max-width: 767px) {
      .dc_season-row {
        display: flex;
        width: 100%;
        margin-top: 6px;
      }
    }
  </style>

  {% if block.settings.show_season_price
    or block.settings.use_season_tag
    or product.metafields.custom.use_season_price.value
  %}
    {% if template.name != 'product' %}
      <div class="dc_season-row">
        {% unless use_season_price_from_variants %}
          {% if block.settings.show_season_price or product.metafields.custom.use_season_price.value %}
            <div class="dc_season-price-box" style="background-color: #fad6c6; padding: 2px; margin-left:2px;">
              <span style="color: #FF5413; font-size:16px;">{{ final_season_price | money }}</span>
            </div>
          {% endif %}
        {% else %}
          {% if season_price_from_variant %}
            <div class="dc_season-price-box" style="background-color: #fad6c6; padding: 2px; margin-left:2px;">
              <span style="color: #FF5413; font-size:16px;">{{ season_price_from_variant | money }}</span>
            </div>
          {% endif %}
        {% endunless %}
      </div>
    {% else %}
      <div class="dc_season-row">
        {% if block.settings.use_season_tag or product.metafields.custom.use_season_price.value %}
          <div class="dc_season-tag" style="color: {{ block.settings.season_tag_color }};">
            {% if product.metafields.custom.season_tag_text.value != blank %}
              {{ product.metafields.custom.season_tag_text.value | escape }}
            {% else %}
              {{ block.settings.season_tag_text | escape }}
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  {% endif %}
  <div class="f-price__unit-wrapper{% if selected_variant.unit_price_measurement == nil %} hidden{% endif %}">
    <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
    <div class="f-price__unit">
      {%- capture unit_price_separator -%}
        <span aria-hidden="true">/</span><span class="visually-hidden">{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
      {%- endcapture -%}
      {%- capture unit_price_base_unit -%}
        <span data-unit-price-base-unit>
            {%- if selected_variant.unit_price_measurement -%}
              {%- if selected_variant.unit_price_measurement.reference_value != 1 -%}
                {{- selected_variant.unit_price_measurement.reference_value -}}
              {%- endif -%}
              {{ selected_variant.unit_price_measurement.reference_unit }}
            {%- endif -%}
          </span>
      {%- endcapture -%}
      <span data-unit-price>{{ selected_variant.unit_price | money }}</span>
      {{- unit_price_separator -}}
      {{- unit_price_base_unit -}}
    </div>
  </div>
</div>
